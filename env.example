# nanobot backend — outer host is the same; only these change the LLM.

# --- Grok cloud (default) — browser device-code session ---
# NANOBOT_BASE_URL=https://127.0.0.1:8080/v1
# NANOBOT_MODEL=grok-4.5

# --- Offline / llama.cpp (OpenAI-compatible server) ---
# Start llama.cpp server, then either:
#   nanobot --offline
#   nanobot --base-url http://127.0.0.1:8080/v1 --model my-gguf
# NANOBOT_BASE_URL=http://127.0.0.1:8080/v1
# NANOBOT_MODEL=local
# NANOBOT_API_KEY=          # optional; many local servers ignore auth
# NANOBOT_TOOLS=0          # set 0 if the server has no tool/function calling

# NANOBOT_HOME=/tmp/nanobot
