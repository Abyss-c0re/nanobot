# Copy to $NANOBOT_HOME/env or export in shell.

# --- Cloud provider (default when unset) ---
# Browser device-code: nanobot --login  or open /activate on the peer port.
# Unofficial interop only — see LEGAL.md (not affiliated).
# NANOBOT_BASE_URL=https://cli-chat-proxy.grok.com/v1
# NANOBOT_MODEL=grok-4.5

# --- Local OpenAI-compatible (no browser) ---
# nanobot --offline
# NANOBOT_BASE_URL=http://127.0.0.1:8080/v1
# NANOBOT_MODEL=local

# Peer / home
# NANOBOT_HOME=$HOME/.nanobot
# NANOBOT_PEER_TOKEN=
# NANOBOT_PORT=8787

# Optional external master key (advanced)
# NANOBOT_MASTER_KEY=/path/to/master.key
# NANOBOT_REQUIRE_MASTER=0
