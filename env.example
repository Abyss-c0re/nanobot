# Example environment for $NANOBOT_HOME/env or process env.
# Do not commit real secrets. Copy ideas only.

# --- Outer host ---
# NANOBOT_HOME=~/.nanobot
# NANOBOT_LEAN=1                    # force lean caps (auto if MemTotal < 400MB)
# NANOBOT_TOOLS=0                   # disable LLM tools if backend lacks them
# NANOBOT_WWW=/path/to/static       # optional static files only

# --- Grok cloud (default if unset) ---
# NANOBOT_BASE_URL=https://127.0.0.1:8080/v1
# NANOBOT_MODEL=grok-4.5
# Auth: device-code via --login or /activate. Session file is separate.

# --- Local OpenAI-compatible (llama.cpp, etc.) ---
# NANOBOT_BASE_URL=http://127.0.0.1:8080/v1
# NANOBOT_MODEL=local
# NANOBOT_API_KEY=

# --- Peer bus ---
# NANOBOT_PEER_TOKEN=...            # or file $NANOBOT_HOME/peer_token
