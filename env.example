# Copy to $NANOBOT_HOME/env or export in shell.
# Default backend is local OpenAI-compatible (e.g. llama.cpp on :8080).

# --- Local OpenAI-compatible (default) ---
# NANOBOT_BASE_URL=http://127.0.0.1:8080/v1
# NANOBOT_MODEL=local

# --- Optional cloud device-code backend (set explicitly) ---
# NANOBOT_BASE_URL=https://your-provider.example/v1
# NANOBOT_MODEL=your-model

# Peer
# NANOBOT_HOME=$HOME/.nanobot
# NANOBOT_PEER_TOKEN=
# NANOBOT_PORT=8787

# Optional external master key file (advanced)
# NANOBOT_MASTER_KEY=/path/to/master.key
# NANOBOT_REQUIRE_MASTER=0
