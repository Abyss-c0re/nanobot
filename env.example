# Example environment for $NANOBOT_HOME/env
# Do not commit real secrets.

# --- Grok cloud (default if unset) ---
# NANOBOT_BASE_URL=https://127.0.0.1:8080/v1
# NANOBOT_MODEL=grok-4.5
# Auth: use UI "Connect Grok" (device-code). Session file is separate.

# --- Local OpenAI-compatible (llama.cpp, etc.) ---
# NANOBOT_BASE_URL=http://127.0.0.1:8080/v1
# NANOBOT_MODEL=local
# NANOBOT_API_KEY=
# NANOBOT_TOOLS=0

# NANOBOT_HOME=~/.nanobot
