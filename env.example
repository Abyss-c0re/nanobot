# Copy to $NANOBOT_HOME/env or export in shell.

# --- Cloud provider + web device-code (default) ---
# nanobot --login  or  open /activate on peer port
# NANOBOT_BASE_URL=https://cli-chat-proxy.grok.com/v1
# NANOBOT_MODEL=grok-4.5

# --- Local OpenAI-compatible (no browser) ---
# nanobot --offline
# NANOBOT_BASE_URL=http://127.0.0.1:8080/v1
# NANOBOT_MODEL=local

# Peer
# NANOBOT_HOME=$HOME/.nanobot
# NANOBOT_PORT=8787
# NANOBOT_PEER_TOKEN=

# Optional master key (advanced)
# NANOBOT_LABAUTH_MASTER=/path/to/master.key

# --- Portability (hosts set these; no product OS paths in the binary) ---
# Shared home across UIDs: write secrets as 0666
# NANOBOT_SHARED_SECRETS=1
# Optional second path for shell gate password file (absolute)
# NANOBOT_GATE_MIRROR=/path/to/gate.blake2b
# Personal-files ACL (only active when roots are configured)
# NANOBOT_FILES_ACL=deny|read|full
# NANOBOT_PERSONAL_ROOTS=/home/me/Documents:/home/me/Pictures
# TMPDIR=…   # preferred temp for mkstemp
