#!/bin/sh
# curl subset via busybox wget (tiny image)
set -eu
method=GET
post=
h1=; h2=; h3=; hn=0
timeout=30
out=
fail=0
url=
while [ $# -gt 0 ]; do
  case "$1" in
    -f) fail=1; shift ;;
    -s|-S|-fsS|-fs|-sS|-fSs|-Ss) shift ;;
    -X) method=$2; shift 2 ;;
    -H)
      hn=$((hn + 1))
      case $hn in
        1) h1=$2 ;;
        2) h2=$2 ;;
        3) h3=$2 ;;
      esac
      shift 2
      ;;
    -d) post=$2; method=POST; shift 2 ;;
    -m) timeout=$2; shift 2 ;;
    -o) out=$2; shift 2 ;;
    -w) shift 2 ;;
    -*) shift ;;
    *) url=$1; shift; break ;;
  esac
done
[ -n "${url:-}" ] || { echo "usage: http URL" >&2; exit 2; }

set -- -T "$timeout" -q
[ -n "$out" ] && set -- "$@" -O "$out" || set -- "$@" -O -
[ -n "$h1" ] && set -- "$@" --header "$h1"
[ -n "$h2" ] && set -- "$@" --header "$h2"
[ -n "$h3" ] && set -- "$@" --header "$h3"

rc=0
if [ -n "$post" ] || [ "$method" = "POST" ] || [ "$method" = "PUT" ]; then
  tmp=$(mktemp)
  printf '%s' "${post:-}" > "$tmp"
  wget "$@" --post-file "$tmp" "$url" || rc=$?
  rm -f "$tmp"
else
  wget "$@" "$url" || rc=$?
fi
if [ "$rc" -ne 0 ]; then
  [ "$fail" = 1 ] && exit 22
  exit "$rc"
fi
exit 0
